{
  "name": "kafka-mcp-server",
  "description": "Kafka MCP Server exposing Apache Kafka operations as tools for AI assistants",
  "version": "0.1.0",
  "author": "Simon Owusu",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "bin": {
    "kafka-mcp-server": "./dist/index.js"
  },
  "keywords": [
    "kafka",
    "mcp",
    "mcp-server",
    "aws-msk",
    "confluent"
  ],
  "files": [
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify --sourcemap=external",
    "build:dev": "bun build ./src/index.ts --outdir ./dist --target bun --sourcemap=inline",
    "start": "bun run dist/index.js",
    "inspector": "bunx --bun @modelcontextprotocol/inspector bun ./dist/index.js",
    "build:inspector": "bun run build && bun run inspector",
    "dev": "bun run src/index.ts",
    "dev:hot": "bun --hot run src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "bunx tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "biome:check": "biome check .",
    "biome:check:write": "biome check --write ."
  },
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "latest",
    "@types/pino": "^7.0.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-kafka": "^3.1012.0",
    "@elastic/ecs-pino-format": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@platformatic/kafka": "^1.30.0",
    "aws-msk-iam-sasl-signer-js": "^1.0.3",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
