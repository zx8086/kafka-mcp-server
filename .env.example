# ============================================================================
# Kafka MCP Server -- Environment Variables
# Copy this file to .env and fill in your values. Bun loads .env automatically.
# ============================================================================

# --- Core -------------------------------------------------------------------

# Provider type: "local", "msk", or "confluent"
KAFKA_PROVIDER=local

# Kafka client identifier (appears in broker logs)
KAFKA_CLIENT_ID=kafka-mcp-server

# Enable write tools (produce, create topic, alter config, register schema, etc.)
KAFKA_ALLOW_WRITES=false

# Enable destructive tools (delete topic, reset offsets, delete schema subject)
KAFKA_ALLOW_DESTRUCTIVE=false

# Max messages returned per consume call (1+)
KAFKA_CONSUME_MAX_MESSAGES=50

# Consume timeout in milliseconds (1+)
KAFKA_CONSUME_TIMEOUT_MS=30000

# --- Local Provider ---------------------------------------------------------

# Comma-separated broker addresses for the local provider
LOCAL_BOOTSTRAP_SERVERS=localhost:9092

# --- AWS MSK Provider -------------------------------------------------------
# Requires valid AWS credentials in the environment (AWS_ACCESS_KEY_ID, etc.)

# Comma-separated MSK broker endpoints (IAM auth port, typically 9098)
# MSK_BOOTSTRAP_BROKERS=b-1.cluster.abc123.kafka.eu-west-1.amazonaws.com:9098

# MSK cluster ARN -- used for IAM auth and broker discovery if brokers omitted
# MSK_CLUSTER_ARN=arn:aws:kafka:eu-west-1:123456789:cluster/my-cluster/abc-123

# AWS region for MSK
# AWS_REGION=eu-west-1

# --- Confluent Cloud Provider -----------------------------------------------

# Bootstrap server address (from Confluent Cloud cluster settings)
# CONFLUENT_BOOTSTRAP_SERVERS=pkc-abc12.eu-west-1.aws.confluent.cloud:9092

# Kafka cluster API key and secret (from Confluent Cloud API keys page)
# CONFLUENT_API_KEY=
# CONFLUENT_API_SECRET=

# REST API endpoint (optional, enables enriched cluster metadata)
# CONFLUENT_REST_ENDPOINT=https://pkc-abc12.eu-west-1.aws.confluent.cloud:443

# Cluster ID (optional, used with REST endpoint)
# CONFLUENT_CLUSTER_ID=lkc-abc123

# --- Schema Registry (optional) ---------------------------------------------

# Enable Schema Registry tools (8 tools)
SCHEMA_REGISTRY_ENABLED=false

# Schema Registry URL
SCHEMA_REGISTRY_URL=http://localhost:8081

# API credentials (required for Confluent Cloud, optional for self-hosted)
# SCHEMA_REGISTRY_API_KEY=
# SCHEMA_REGISTRY_API_SECRET=

# --- ksqlDB (optional) ------------------------------------------------------

# Enable ksqlDB tools (7 tools)
KSQL_ENABLED=false

# ksqlDB REST API endpoint
KSQL_ENDPOINT=http://localhost:8088

# API credentials (required for Confluent Cloud, optional for self-hosted)
# KSQL_API_KEY=
# KSQL_API_SECRET=

# --- Logging ----------------------------------------------------------------

# Log level: "silent", "debug", "info", "warn", "error"
LOG_LEVEL=info

# Logging backend (only "pino" supported)
LOGGING_BACKEND=pino

# --- Telemetry (OpenTelemetry) ----------------------------------------------

# Enable OpenTelemetry tracing and metrics
TELEMETRY_ENABLED=false

# Service name reported in spans
TELEMETRY_SERVICE_NAME=kafka-mcp-server

# Export mode: "console" (stdout), "otlp" (HTTP exporter), or "both"
TELEMETRY_MODE=console

# OTLP HTTP exporter endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
